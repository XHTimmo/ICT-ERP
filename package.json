{
  "name": "erp-system",
  "version": "1.2.2",
  "description": "A simple ERP system for reimbursement management",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --port 5174\" \"wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Timmo",
  "license": "ISC",
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.0.0",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.7.0",
    "fs-extra": "^11.2.0",
    "interactjs": "^1.10.27",
    "pinia": "^2.1.7",
    "uuid": "^9.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/XHTimmo/ICT-ERP.git"
  },
  "build": {
    "appId": "com.xhtimmo.icterp",
    "publish": [
      {
        "provider": "github",
        "owner": "XHTimmo",
        "repo": "ICT-ERP"
      }
    ],
    "productName": "ERP System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
